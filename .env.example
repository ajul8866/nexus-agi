# NEXUS-AGI Environment Configuration

# LLM Provider Keys
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Database
DATABASE_URL=sqlite:///./nexus.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/nexus

# Redis
REDIS_URL=redis://localhost:6379/0

# API Server
NEXUS_HOST=0.0.0.0
NEXUS_PORT=8000
NEXUS_DEBUG=false
NEXUS_SECRET_KEY=change-this-secret-key-in-production

# Memory Settings
MEMORY_EMBEDDING_MODEL=all-MiniLM-L6-v2
MEMORY_VECTOR_DIM=384
MEMORY_MAX_EPISODIC=10000
MEMORY_MAX_SEMANTIC=50000

# Agent Settings
MAX_AGENTS=50
AGENT_TIMEOUT_SECONDS=300
MAX_ITERATIONS_PER_TASK=20

# Safety Settings
SAFETY_LEVEL=high
REQUIRE_HUMAN_APPROVAL_THRESHOLD=0.5
CONSTITUTIONAL_AI_ENABLED=true

# RSI Settings
RSI_ENABLED=true
RSI_MONITOR_INTERVAL_SECONDS=60
RSI_MAX_IMPROVEMENTS_PER_CYCLE=5
